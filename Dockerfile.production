# ================================================================================
# 步骤1：选择静态文件运行镜像
# ================================================================================
# 目标：
# 1) 使用 Nginx 运行预构建的 dist 静态产物
# 2) 避免生产镜像构建阶段接触 Node 依赖和 private-content 源文件
FROM nginx:1.27-alpine

# 1.1 复制 Nginx 站点配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 1.2 复制预构建静态产物
COPY dist /usr/share/nginx/html

# 1.3 暴露容器内 HTTP 端口
EXPOSE 80
