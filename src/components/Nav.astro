---
import { siteIdentity } from '../data/site'

const pathname = Astro.url.pathname

const links = [
  { href: '/blog/', label: 'Blog' },
  { href: '/projects/', label: 'Projects' },
  { href: '/talks/', label: 'Talks' },
  { href: '/about/', label: 'About' },
  { href: siteIdentity.githubUrl, label: 'GitHub', external: true },
]

const isActive = (href: string) => href.startsWith('/') && pathname.startsWith(href)
---

<nav class="site-nav" aria-label="Primary">
  <a class="brand" href="/" aria-label={`${siteIdentity.ownerName} home`}>
    <span class="brand-mark" aria-hidden="true">JT</span>
    <span>{siteIdentity.ownerName}</span>
  </a>

  <div class="nav-links">
    {links.map((link) => (
      <a
        href={link.href}
        aria-current={isActive(link.href) ? 'page' : undefined}
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noreferrer' : undefined}
        class:list={{ active: isActive(link.href) }}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.1rem;
    width: min(var(--content-width), calc(100vw - 2rem));
    margin: 0 auto;
    padding: 0.1rem 0 1rem;
    border-bottom: 1px solid var(--border);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--accent);
    font-size: 0.95rem;
    letter-spacing: 0;
  }

  .brand-mark {
    display: inline-grid;
    width: 1.95rem;
    height: 1.95rem;
    place-items: center;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
    background: var(--surface);
    color: var(--accent);
    font-size: 0.72rem;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.95rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.86rem;
  }

  .nav-links a.active,
  .nav-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .site-nav {
      width: min(var(--content-width), calc(100vw - 1.25rem));
      align-items: flex-start;
    }

    .brand span:last-child {
      display: none;
    }

    .nav-links {
      gap: 0.7rem;
    }
  }

  @media (max-width: 420px) {
    .site-nav {
      gap: 0.8rem;
    }

    .nav-links {
      gap: 0.55rem;
    }

    .nav-links a {
      font-size: 0.82rem;
    }
  }
</style>
