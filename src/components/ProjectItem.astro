---
import Badge from './Badge.astro'
import type { ProjectItemData } from '../utils/projects'

interface Props {
  project: ProjectItemData
}

const { project } = Astro.props
const projectHref = project.href
---

<article class="project-item row-item">
  {projectHref ? (
    <a class="project-link row-link" href={projectHref}>
      <div class="row-main">
        <p class="row-kicker">{project.data.status}</p>
        <h3 class="row-title">{project.data.name}</h3>
        <p class="row-summary">{project.data.description}</p>
      </div>
      <span class="row-arrow" aria-hidden="true">-&gt;</span>
    </a>
  ) : (
    <div class="project-link row-static">
      <div class="row-main">
        <p class="row-kicker">{project.data.status}</p>
        <h3 class="row-title">{project.data.name}</h3>
        <p class="row-summary">{project.data.description}</p>
      </div>
    </div>
  )}

  <div class="tag-row">
    {project.data.tags.map((tag: string) => <Badge label={tag} />)}
  </div>
</article>

<style>
  .project-item > .tag-row {
    padding: 0 0 1rem;
  }
</style>
