---
import type { CollectionEntry } from 'astro:content'

import Badge from './Badge.astro'
import { formatDate } from '../utils/date'

interface Props {
  entries: CollectionEntry<'blog'>[]
}

const { entries } = Astro.props

const articles = entries.map((entry) => ({
  ...entry,
  slug: entry.slug.replace(/\.(md|mdx)$/, ''),
}))
---

<ul class="article-list list-reset">
  {articles.map((entry) => (
    <li class="article-item">
      <a class="article-link" href={`/blog/${entry.slug}/`}>
        <div class="article-topline">
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          <span>{entry.data.readingTime}</span>
        </div>

        <h3>{entry.data.title}</h3>
        <p>{entry.data.description}</p>
      </a>

      <div class="tag-row">
        {entry.data.tags.map((tag: string) => <Badge label={tag} />)}
      </div>
    </li>
  ))}
</ul>

<style>
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .article-item {
    padding: 1rem 0 0;
    border-top: 1px solid var(--border);
  }

  .article-link {
    display: block;
  }

  .article-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
    color: var(--text-faint);
    font-size: 0.85rem;
  }

  .article-link h3 {
    margin-bottom: 0.35rem;
  }

  .article-link p {
    margin-bottom: 0.65rem;
  }
</style>
