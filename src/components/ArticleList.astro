---
import Badge from './Badge.astro'
import { getArticleSeriesHref, getArticleTagHref, getArticleUpdatedDate } from '../utils/articles'
import type { Article } from '../utils/articles'
import { formatDate } from '../utils/date'

interface Props {
  articles: Article[]
}

const { articles } = Astro.props

const articleItems = articles.map((article) => ({
  ...article,
  seriesHref: getArticleSeriesHref(article),
  updatedAt: getArticleUpdatedDate(article),
}))
---

<ul class="article-list list-reset">
  {articleItems.map((entry) => (
    <li class="article-item row-item">
      <a class="article-link row-link" href={entry.href}>
        <div class="row-main">
          <div class="article-topline row-kicker">
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          {entry.updatedAt && <span>Updated {formatDate(entry.updatedAt)}</span>}
          {entry.data.series?.order && <span>Part {entry.data.series.order}</span>}
          <span>{entry.data.readingTime}</span>
          </div>

          <h3 class="row-title">{entry.data.title}</h3>
          <p class="row-summary">{entry.data.description}</p>
        </div>

        <span class="row-arrow" aria-hidden="true">-&gt;</span>
      </a>

      <div class="tag-row">
        {entry.data.series && entry.seriesHref && <Badge label={entry.data.series.title} href={entry.seriesHref} />}
        {entry.data.tags.map((tag: string) => <Badge label={tag} href={getArticleTagHref(tag)} />)}
      </div>
    </li>
  ))}
</ul>

<style>
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .article-item > .tag-row {
    padding: 0 0 1rem;
  }
</style>
