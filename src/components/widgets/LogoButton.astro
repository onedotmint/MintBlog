---
import Link from '~/components/base/Link.astro'
import { withBasePath } from '~/utils/path'
import { SITE } from '~/config'
---

<Link
  class="select-none op-transition"
  href={withBasePath('/')}
  aria-label={`${SITE.author} / onedotmint`}
  aria-current={Astro.url.pathname === `${withBasePath('/')}` ? 'page' : false}
>
  <div class="logo-container">
    <img
      src={withBasePath('/onedotmint-wordmark.svg')}
      width="2048"
      height="682"
      alt="onedotmint"
      decoding="async"
    />
  </div>
</Link>

<style>
  .logo-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.8rem;

    transform: translate(-0.18rem, -0.16rem) scale(1.08);
  }

  @media (max-width: 767.9px) {
    .logo-container {
      margin-top: 0.125rem;

      transform-origin: 0%;
      transform: translate(-0.12rem, -0.08rem) scale(1);
    }
  }

  .logo-container img {
    display: block;
    height: 2.25rem;
    width: auto;
  }
</style>
