---
import Badge from '../components/Badge.astro'
import Layout from '../layouts/Layout.astro'
import SectionTitle from '../components/SectionTitle.astro'
import { siteIdentity } from '../data/site'
---

<Layout
  title="About"
  description={`${siteIdentity.ownerName}'s short introduction, learning route, technical interests, current focus, and contact links.`}
>
  <section class="section page-intro identity-grid">
    <div class="watermark" aria-hidden="true">About</div>

    <div class="identity-stack">
      <p class="eyebrow">About</p>
      <h1 class="hero-title">{siteIdentity.ownerName}</h1>
      <p class="lead">
        {siteIdentity.aboutIntro}
      </p>
    </div>

    <aside class="identity-rows" aria-label="Profile summary">
      <div class="identity-row">
        <span>Role</span>
        <strong>Developer, maintainer, systems learner</strong>
      </div>
      <div class="identity-row">
        <span>Stack</span>
        <strong>Astro, MDX, TypeScript, Go, Linux</strong>
      </div>
      <div class="identity-row">
        <span>Contact</span>
        <a class="text-link" href={siteIdentity.githubUrl}>GitHub -&gt;</a>
      </div>
    </aside>
  </section>

  <section class="section prose">
    <SectionTitle title="Working route" />
    <ul>
      <li>Core CS notes that turn coursework into reusable mental models.</li>
      <li>Linux, networking, and services that stay easy to inspect.</li>
      <li>Static web delivery with Astro and simple build pipelines.</li>
    </ul>
  </section>

  <section class="section prose">
    <SectionTitle title="Technical interests" />
    <div class="badge-row">
      <Badge label="Go" />
      <Badge label="Rust" />
      <Badge label="Linux" />
      <Badge label="Nginx" />
      <Badge label="Astro" />
      <Badge label="MDX" />
    </div>
  </section>

  <section class="section prose">
    <SectionTitle title="Current focus" />
    <p>
      The current work is keeping this site small, making content files easy to maintain, and writing down the decisions that keep static software useful.
    </p>
  </section>

  <section class="section prose">
    <SectionTitle title="Elsewhere" />
    <div class="link-row">
      <a class="text-link" href={siteIdentity.githubUrl}>GitHub -&gt;</a>
      <a class="text-link" href="/blog/">Blog -&gt;</a>
      <a class="text-link" href="/reading/">Reading -&gt;</a>
      <a class="text-link" href="/now/">Now -&gt;</a>
      {siteIdentity.emailAddress ? (
        <a class="text-link" href={`mailto:${siteIdentity.emailAddress}`}>Email -&gt;</a>
      ) : null}
    </div>
  </section>
</Layout>
