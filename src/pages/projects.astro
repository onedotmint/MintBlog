---
import Layout from '../layouts/Layout.astro'
import Badge from '../components/Badge.astro'
import ProjectList from '../components/ProjectList.astro'
import { getGroupedProjects } from '../utils/projects'

const projectGroups = await getGroupedProjects()
---

<Layout
  title="Projects"
  description="Small tools, systems labs, and static-first experiments."
>
  <section class="section page-intro project-index">
    <div class="watermark" aria-hidden="true">Build</div>
    <div class="prose centered-intro">
      <p class="eyebrow">Projects</p>
      <h1 class="hero-title">Projects</h1>
      <p class="lead">
        Small tools, systems labs, and static-first experiments. The useful parts are the constraints, tradeoffs, and follow-up notes.
      </p>
    </div>

    <nav class="tab-row project-actions" aria-label="Project shortcuts">
      <Badge label="All projects" href="#project-list" active ariaCurrent="location" />
      <Badge label="Blog notes" href="/blog/" />
      <Badge label="Current focus" href="/now/" />
    </nav>
  </section>

  <section id="project-list" class="section">
    <ProjectList groups={projectGroups} />
  </section>
</Layout>

<style>
  .project-index {
    text-align: center;
  }

  .centered-intro {
    margin: 0 auto;
  }

  .project-actions {
    justify-content: center;
  }
</style>
