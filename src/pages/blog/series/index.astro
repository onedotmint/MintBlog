---
import ArticleList from '../../../components/ArticleList.astro'
import Layout from '../../../layouts/Layout.astro'
import SectionTitle from '../../../components/SectionTitle.astro'
import { getArticleSeries, getArticles } from '../../../utils/articles'

const articles = await getArticles()
const articleSeries = getArticleSeries(articles)
---

<Layout
  title="Article Series"
  description="Long-running blog notes grouped into readable sequences."
>
  <section class="section prose">
    <a class="back-link" href="/blog/">
      Back to blog
    </a>

    <SectionTitle title="Article Series" description="Long-running notes grouped into readable sequences." />
  </section>

  <section class="section">
    <ul class="series-list list-reset">
      {articleSeries.map((series) => (
        <li class="series-item">
          <a href={series.href}>
            <h3>{series.title}</h3>
            <p>{series.articles.length} {series.articles.length === 1 ? 'article' : 'articles'}</p>
          </a>

          <ArticleList articles={series.articles} />
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    width: fit-content;
    color: var(--text-faint);
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .series-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .series-item {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .series-item h3 {
    margin-bottom: 0.25rem;
  }

  .series-item p {
    margin-bottom: 0;
    color: var(--text-faint);
    font-size: 0.9rem;
  }
</style>
