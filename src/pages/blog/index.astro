---
import ArticleList from '../../components/ArticleList.astro'
import Badge from '../../components/Badge.astro'
import Layout from '../../layouts/Layout.astro'
import SectionTitle from '../../components/SectionTitle.astro'
import { siteIdentity } from '../../data/site'
import { getArticleArchives, getArticleSeries, getArticleTags, getArticles } from '../../utils/articles'

const articles = await getArticles()
const articleArchives = getArticleArchives(articles)
const articleSeries = getArticleSeries(articles)
const articleTags = getArticleTags(articles)
---

<Layout
  title="Blog"
  description={`Field notes, build logs, and small technical writeups from ${siteIdentity.ownerName}.`}
>
  <section class="section page-intro blog-index">
    <div class="watermark" aria-hidden="true">Blog</div>
    <div class="prose">
      <p class="eyebrow">Archive</p>
      <h1 class="hero-title">Blog</h1>
      <p class="lead">
        Field notes, build logs, and short technical writeups. The index is grouped by year so older work stays findable without turning the page into a card wall.
      </p>
    </div>

    <nav class="tab-row" aria-label="Blog sections">
      <Badge label="Archive" href="/blog/archive/" />
      <Badge label="Series" href="/blog/series/" />
      <Badge label="Tags" href="/blog/tags/" />
      {articleTags.map((tag) => <Badge label={`${tag.label} (${tag.articles.length})`} href={tag.href} />)}
    </nav>
  </section>

  {articleSeries.length > 0 && (
    <section class="section">
      <SectionTitle title="Series" description="Long-running notes grouped by topic." />
      <div class="tag-row">
        {articleSeries.map((series) => <Badge label={`${series.title} (${series.articles.length})`} href={series.href} />)}
      </div>
    </section>
  )}

  <div class="article-year-groups">
    {articleArchives.map((archive) => (
      <section class="section split-layout">
        <div class="year-copy">
          <a class="ghost-label" href={archive.href}>{archive.year}</a>
          <p>{archive.articles.length} {archive.articles.length === 1 ? 'article' : 'articles'}</p>
        </div>

        <ArticleList articles={archive.articles} />
      </section>
    ))}
  </div>
</Layout>

<style>
  .blog-index {
    position: relative;
  }

  .article-year-groups {
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }

  .year-copy {
    position: sticky;
    top: 1rem;
  }

  .year-copy p {
    margin: 0.55rem 0 0;
    color: var(--text-faint);
    font-size: 0.9rem;
  }

  .year-copy .ghost-label {
    display: inline-flex;
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .year-copy {
      position: static;
    }
  }
</style>
