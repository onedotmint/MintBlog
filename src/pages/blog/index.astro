---
import ArticleList from '../../components/ArticleList.astro'
import Badge from '../../components/Badge.astro'
import Layout from '../../layouts/Layout.astro'
import SectionTitle from '../../components/SectionTitle.astro'
import { siteIdentity } from '../../data/site'
import { getArticleArchives, getArticleSeries, getArticleTags, getArticles } from '../../utils/articles'

const articles = await getArticles()
const articleArchives = getArticleArchives(articles)
const articleSeries = getArticleSeries(articles)
const articleTags = getArticleTags(articles)
---

<Layout
  title="Blog"
  description={`Field notes, build logs, and small technical writeups from ${siteIdentity.ownerName}.`}
>
  <section class="section prose blog-index">
    <div class="watermark" aria-hidden="true">2026</div>
    <SectionTitle title="Blog" description="Field notes, build logs, and short writeups." />

    <p class="lead">
      A static index for the posts that matter most. Topics stay small, practical, and close to the work.
    </p>

    <div class="tag-row surface">
      <Badge label="Archive" href="/blog/archive/" />
      {articleTags.map((tag) => <Badge label={`${tag.label} (${tag.articles.length})`} href={tag.href} />)}
    </div>
  </section>

  {articleArchives.length > 0 && (
    <section class="section">
      <SectionTitle title="Archive" description="Posts grouped by publication year." />
      <div class="tag-row">
        {articleArchives.map((archive) => (
          <Badge
            label={`${archive.year} (${archive.articles.length})`}
            href={archive.href}
          />
        ))}
      </div>
    </section>
  )}

  {articleSeries.length > 0 && (
    <section class="section">
      <SectionTitle title="Series" description="Long-running notes grouped by topic." />
      <div class="tag-row">
        {articleSeries.map((series) => <Badge label={`${series.title} (${series.articles.length})`} href={series.href} />)}
      </div>
    </section>
  )}

  <section class="section">
    <ArticleList articles={articles} />
  </section>
</Layout>

<style>
  .blog-index {
    position: relative;
  }
</style>
