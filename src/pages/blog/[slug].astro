---
import type { CollectionEntry } from 'astro:content'

import Badge from '../../components/Badge.astro'
import BackLink from '../../components/BackLink.astro'
import ArticleList from '../../components/ArticleList.astro'
import ArticleReadingNav from '../../components/ArticleReadingNav.astro'
import ArticleTableOfContents from '../../components/ArticleTableOfContents.astro'
import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'
import {
  getAdjacentArticles,
  getArticles,
  getArticleSeriesHref,
  getArticleTableOfContents,
  getArticleTagHref,
  getArticleUpdatedDate,
  getRelatedArticles,
  toArticle,
} from '../../utils/articles'

export async function getStaticPaths() {
  const articles = await getArticles()

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { entry: article.entry },
  }))
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> }
const { Content, headings } = await entry.render()
const article = toArticle(entry)
const articles = await getArticles()
const updatedAt = getArticleUpdatedDate(article)
const seriesHref = getArticleSeriesHref(article)
const relatedArticles = getRelatedArticles(article, articles)
const adjacentArticles = getAdjacentArticles(article, articles)
const tableOfContents = getArticleTableOfContents(headings)
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={article.href}
  type="article"
  articleMetadata={{
    publishedAt: entry.data.date,
    updatedAt,
    tags: entry.data.tags,
  }}
>
  <article class="section prose article-detail" aria-labelledby="article-title">
    <BackLink href="/blog/">Back to blog</BackLink>

    <header class="post-header">
      <p class="eyebrow">Article</p>
      <h1 id="article-title">{entry.data.title}</h1>

      <div class="meta-row">
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        {updatedAt && <span>Updated {formatDate(updatedAt)}</span>}
        {entry.data.series?.order && <span>Part {entry.data.series.order}</span>}
        <span>{entry.data.readingTime}</span>
      </div>

      <div class="tag-row">
        {entry.data.series && seriesHref && <Badge label={entry.data.series.title} href={seriesHref} />}
        {entry.data.tags.map((tag: string) => <Badge label={tag} href={getArticleTagHref(tag)} />)}
      </div>

      <a class="skip-reading-link" href="#article-content">
        Skip to article
      </a>
    </header>

    <ArticleTableOfContents items={tableOfContents} />

    <div id="article-content" class="post-body" tabindex="-1">
      <Content />
    </div>

    <ArticleReadingNav newer={adjacentArticles.newer} older={adjacentArticles.older} />

    {relatedArticles.length > 0 && (
      <section class="related-section">
        <h2>Related articles</h2>
        <ArticleList articles={relatedArticles} />
      </section>
    )}
  </article>
</Layout>

<style>
  .post-header {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .skip-reading-link {
    position: absolute;
    transform: translateY(-120%);
    opacity: 0;
    pointer-events: none;
    width: fit-content;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    background: var(--bg-elevated);
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 0.22em;
  }

  .skip-reading-link:focus-visible {
    transform: translateY(-25%);
    opacity: 1;
    pointer-events: auto;
    color: var(--accent);
    text-decoration-color: var(--accent-muted);
  }

  .post-body {
    max-width: 760px;
    scroll-margin-top: 1rem;
  }

  .post-body:focus {
    outline: none;
  }

  .related-section {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .post-body :global(h2) {
    margin-top: 2.2rem;
    margin-bottom: 0.7rem;
    font-size: 1.35rem;
    scroll-margin-top: 1rem;
  }

  .post-body :global(h3) {
    margin-top: 1.6rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    scroll-margin-top: 1rem;
  }

  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1rem;
  }

  .post-body :global(p) {
    line-height: 1.75;
  }

  .post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 0.22em;
  }

  .post-body :global(a:hover) {
    text-decoration-color: var(--accent-muted);
  }

  .post-body :global(li) {
    padding-left: 0.12rem;
  }

  .post-body :global(li::marker) {
    color: var(--text-faint);
  }

  .post-body :global(img) {
    height: auto;
    margin: 1.2rem 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .post-body :global(figure) {
    margin: 1.4rem 0;
  }

  .post-body :global(figcaption) {
    margin-top: 0.55rem;
    color: var(--text-faint);
    font-size: 0.88rem;
  }

  .post-body :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    margin: 1.2rem 0;
  }

  .post-body :global(th),
  .post-body :global(td) {
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }

  .post-body :global(th) {
    color: var(--accent);
    font-weight: 600;
  }

  .post-body :global(pre) {
    max-width: 100%;
    margin: 1.2rem 0;
  }

  @media (max-width: 720px) {
    .article-detail {
      gap: 0.95rem;
    }

    .post-header {
      gap: 0.75rem;
    }

    .post-body :global(p) {
      line-height: 1.7;
    }
  }
</style>
