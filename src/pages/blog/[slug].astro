---
import type { CollectionEntry } from 'astro:content'

import Badge from '../../components/Badge.astro'
import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'
import { getArticles, getArticleSeriesHref, getArticleUpdatedDate, toArticle } from '../../utils/articles'

export async function getStaticPaths() {
  const articles = await getArticles()

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { entry: article.entry },
  }))
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> }
const { Content } = await entry.render()
const article = toArticle(entry)
const updatedAt = getArticleUpdatedDate(article)
const seriesHref = getArticleSeriesHref(article)
---

<Layout title={entry.data.title} description={entry.data.description} canonicalPath={article.href} type="article">
  <article class="section prose">
    <a class="back-link" href="/blog/">
      Back to blog
    </a>

    <header class="post-header">
      <p class="eyebrow">Article</p>
      <h1>{entry.data.title}</h1>

      <div class="meta-row">
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        {updatedAt && <span>Updated {formatDate(updatedAt)}</span>}
        {entry.data.series?.order && <span>Part {entry.data.series.order}</span>}
        <span>{entry.data.readingTime}</span>
      </div>

      <div class="tag-row">
        {entry.data.series && seriesHref && <Badge label={entry.data.series.title} href={seriesHref} />}
        {entry.data.tags.map((tag: string) => <Badge label={tag} />)}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    width: fit-content;
    color: var(--text-faint);
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .post-body {
    max-width: 760px;
  }

  .post-body :global(h2) {
    margin-top: 1.9rem;
    margin-bottom: 0.6rem;
    font-size: 1.35rem;
  }

  .post-body :global(h3) {
    margin-top: 1.4rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1rem;
  }
</style>
