---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'

import Badge from '../../components/Badge.astro'
import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'

export async function getStaticPaths() {
  const posts = (await getCollection('blog')) as CollectionEntry<'blog'>[]

  return posts.map((entry: CollectionEntry<'blog'>) => ({
    params: { slug: entry.slug.replace(/\.(md|mdx)$/, '') },
    props: { entry },
  }))
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> }
const { Content } = await entry.render()
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article class="section prose">
    <a class="back-link" href="/blog/">
      Back to blog
    </a>

    <header class="post-header">
      <p class="eyebrow">Article</p>
      <h1>{entry.data.title}</h1>

      <div class="meta-row">
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        <span>{entry.data.readingTime}</span>
      </div>

      <div class="tag-row">
        {entry.data.tags.map((tag: string) => <Badge label={tag} />)}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    width: fit-content;
    color: var(--text-faint);
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .post-body {
    max-width: 760px;
  }

  .post-body :global(h2) {
    margin-top: 1.9rem;
    margin-bottom: 0.6rem;
    font-size: 1.35rem;
  }

  .post-body :global(h3) {
    margin-top: 1.4rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: 1rem;
  }
</style>
