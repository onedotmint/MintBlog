---
import Badge from '../components/Badge.astro'
import ArticleList from '../components/ArticleList.astro'
import Layout from '../layouts/Layout.astro'
import ProjectList from '../components/ProjectList.astro'
import SectionTitle from '../components/SectionTitle.astro'
import { siteIdentity } from '../data/site'
import { getArticles, getFeaturedArticles } from '../utils/articles'
import { getGroupedProjects } from '../utils/projects'

const articles = await getArticles()
const featuredArticles = getFeaturedArticles(articles, 3)
const projectGroups = await getGroupedProjects()
const featuredGroups = projectGroups.map((group) => ({
  ...group,
  items: group.items.slice(0, 1),
}))

const entryActions = [
  { href: '/blog/', label: 'Blog', note: 'Articles, build logs, field notes' },
  { href: '/projects/', label: 'Projects', note: 'Tools, labs, shipped experiments' },
  { href: '/talks/', label: 'Talks', note: 'Talk notes and drafts' },
]
---

<Layout
  title={siteIdentity.defaultTitle}
  description={`${siteIdentity.ownerName} writes about backend systems, small experiments, and the notes that keep both readable.`}
>
  <section class="section page-intro identity-grid">
    <div class="watermark" aria-hidden="true">JT</div>

    <div class="identity-stack">
      <p class="eyebrow">Independent developer</p>
      <h1 class="hero-title">{siteIdentity.ownerName}</h1>
      <p class="lead">
        {siteIdentity.shortIntro}
      </p>

      <nav class="entry-actions" aria-label="Homepage entry points">
        {entryActions.map((action) => (
          <a class="entry-action" href={action.href}>
            <span>{action.label}</span>
            <small>{action.note}</small>
          </a>
        ))}
      </nav>

      <div class="link-row">
        <a class="text-link" href="/reading/">Reading -&gt;</a>
        <a class="text-link" href="/now/">Now -&gt;</a>
      </div>
    </div>

    <aside class="identity-rows" aria-label="Site identity">
      <div class="identity-row">
        <span>Focus</span>
        <strong>Backend systems, static tooling, interface detail</strong>
      </div>
      <div class="identity-row">
        <span>Mode</span>
        <strong>Open-source maintenance and public notes</strong>
      </div>
      <div class="identity-row">
        <span>Elsewhere</span>
        <a class="text-link" href={siteIdentity.githubUrl}>GitHub -&gt;</a>
      </div>
      <div class="badge-row">
        <Badge label="Systems" />
        <Badge label="Astro" />
        <Badge label="MDX" />
        <Badge label="Design engineering" />
      </div>
    </aside>
  </section>

  <section class="section">
    <SectionTitle title="Recent articles" description="Selected notes from the public archive." />
    <ArticleList articles={featuredArticles} />
  </section>

  <section class="section">
    <SectionTitle title="Recent projects" description="Small builds and current experiments." />
    <ProjectList groups={featuredGroups} />
  </section>
</Layout>

<style>
  .entry-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    max-width: 40rem;
  }

  .entry-action {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.78rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .entry-action:hover {
    border-color: var(--border-strong);
    background: var(--surface-hover);
  }

  .entry-action span,
  .entry-action small {
    overflow-wrap: anywhere;
  }

  .entry-action span {
    color: var(--accent);
    font-size: 0.94rem;
    line-height: 1.2;
  }

  .entry-action small {
    color: var(--text-faint);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  @media (max-width: 720px) {
    .entry-actions {
      grid-template-columns: 1fr;
      max-width: 100%;
    }
  }
</style>
