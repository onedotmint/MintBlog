---
import Badge from '../../components/Badge.astro'
import BackLink from '../../components/BackLink.astro'
import Layout from '../../layouts/Layout.astro'
import { getDetailedProjects } from '../../utils/projects'
import type { ProjectLink, ProjectWithDetail } from '../../utils/projects'

interface Props {
  project: ProjectWithDetail
}

export async function getStaticPaths() {
  const projects = await getDetailedProjects()

  return projects.map((project) => ({
    params: {
      slug: project.slug,
    },
    props: {
      project,
    },
  }))
}

const { project } = Astro.props
const { Content } = await project.entry.render()
---

<Layout
  title={project.data.name}
  description={project.data.summary}
  canonicalPath={project.href}
>
  <article class="project-detail">
    <header class="section prose project-hero">
      <BackLink href="/projects/">Projects</BackLink>
      <p class="eyebrow">Project</p>
      <h1>{project.data.name}</h1>
      <p class="lead">{project.data.summary}</p>
      <div class="tag-row">
        {project.data.tags.map((tag: string) => <Badge label={tag} />)}
      </div>
    </header>

    <section class="section project-section">
      <h2>Background</h2>
      <div class="prose">
        <Content />
      </div>
    </section>

    <section class="section project-section">
      <h2>Design Notes</h2>
      <ul>
        {project.data.designNotes.map((note: string) => <li>{note}</li>)}
      </ul>
    </section>

    <section class="section project-section">
      <h2>Related Links</h2>
      <ul class="list-reset project-links">
        {project.data.links.map((link: ProjectLink) => (
          <li>
            <a href={link.href}>
              <span>{link.label}</span>
              <span aria-hidden="true">-&gt;</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="section project-section">
      <h2>Retrospective</h2>
      <p>{project.data.retrospective}</p>
    </section>
  </article>
</Layout>

<style>
  .project-detail {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-hero {
    gap: 0.7rem;
  }

  .project-section {
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
  }

  .project-section p,
  .project-section li {
    color: var(--text-muted);
  }

  .project-section ul {
    margin-bottom: 0;
  }

  .project-links {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .project-links a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }

  .project-links a:hover {
    color: var(--accent);
    border-color: var(--border-strong);
  }
</style>
