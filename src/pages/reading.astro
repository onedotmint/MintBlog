---
import Badge from '../components/Badge.astro'
import Layout from '../layouts/Layout.astro'
import ReadingResourceList from '../components/ReadingResourceList.astro'
import { getReadingResourceGroups, getReadingResources } from '../utils/reading'

const resources = await getReadingResources()
const groups = getReadingResourceGroups(resources)
const hasGroups = groups.length > 0
---

<Layout
  title="Reading"
  description="Courses, books, documentation, and technical references used while learning."
>
  <section id="reading-all" class="section page-intro reading-index">
    <div class="watermark" aria-hidden="true">Read</div>
    <div class="prose">
      <p class="eyebrow">Reading</p>
      <h1 class="hero-title">Reading</h1>
      <p class="lead">
        Courses, books, documentation, and references worth keeping close. Each entry opens a detail page with the full notes.
      </p>
    </div>

    {hasGroups && (
      <nav class="tab-row" aria-label="Reading categories">
        <Badge label="All" href="#reading-all" active ariaCurrent="location" />
        {groups.map((group) => (
          <Badge label={group.type} href={group.href} />
        ))}
      </nav>
    )}
  </section>

  <section class="section">
    <ReadingResourceList groups={groups} />
  </section>
</Layout>

<style>
  .reading-index {
    position: relative;
  }
</style>
