---
import Badge from '../components/Badge.astro'
import Layout from '../layouts/Layout.astro'
import ReadingResourceList from '../components/ReadingResourceList.astro'
import SectionTitle from '../components/SectionTitle.astro'
import { getReadingResourceGroups, getReadingResources } from '../utils/reading'

const resources = await getReadingResources()
const groups = getReadingResourceGroups(resources)
const hasGroups = groups.length > 0
---

<Layout
  title="Reading"
  description="Courses, books, documentation, and technical references used while learning."
>
  <section id="reading-all" class="section prose reading-index">
    <SectionTitle
      title="Reading"
      description="Courses, books, documentation, and technical references used while learning."
    />

    <p class="lead">
      A static index for the resources worth keeping close. Each entry opens a detail page with the full notes.
    </p>

    {hasGroups && (
      <nav class="reading-shortcuts" aria-label="Reading categories">
        <Badge label="All" href="#reading-all" active ariaCurrent="location" />
        {groups.map((group) => (
          <Badge label={group.type} href={group.href} />
        ))}
      </nav>
    )}
  </section>

  <section class="section">
    <ReadingResourceList groups={groups} />
  </section>
</Layout>

<style>
  .reading-index {
    position: relative;
  }

  .reading-shortcuts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
</style>
