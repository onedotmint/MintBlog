---
import { render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

import Badge from '../../components/Badge.astro'
import BackLink from '../../components/BackLink.astro'
import Layout from '../../layouts/Layout.astro'
import { getReadingResourceExternalHref, getReadingResources, toReadingResource } from '../../utils/reading'

export async function getStaticPaths() {
  const resources = await getReadingResources()

  return resources.map((resource) => ({
    params: {
      slug: resource.slug,
    },
    props: {
      entry: resource.entry,
    },
  }))
}

const { entry } = Astro.props as { entry: CollectionEntry<'reading'> }
const resource = toReadingResource(entry)
const externalHref = getReadingResourceExternalHref(resource)
const { Content } = await render(entry)
---

<Layout title={entry.data.title} description={entry.data.note} canonicalPath={resource.href} type="article">
  <article class="section prose reading-detail">
    <BackLink href="/reading/">Back to reading</BackLink>

    <header class="reading-hero">
      <p class="eyebrow">{entry.data.type}</p>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.note}</p>

      <div class="tag-row">
        {entry.data.tags.map((tag: string) => <Badge label={tag} />)}
        {externalHref && <Badge label="Source" href={externalHref} />}
      </div>
    </header>

    {entry.data.image && (
      <figure class="reading-image">
        <img src={entry.data.image} alt={entry.data.title} />
      </figure>
    )}

    <div class="reading-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .reading-detail {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .reading-hero {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .reading-image {
    margin: 0;
  }

  .reading-image img {
    width: 100%;
    max-width: 42rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .reading-body {
    max-width: 760px;
  }

  .reading-body :global(h2) {
    margin-top: 1.9rem;
    margin-bottom: 0.6rem;
    font-size: 1.35rem;
  }

  .reading-body :global(h3) {
    margin-top: 1.4rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .reading-body :global(p),
  .reading-body :global(ul),
  .reading-body :global(ol) {
    margin-bottom: 1rem;
  }
</style>
