---
import '../styles/global.css'
import Footer from '../components/Footer.astro'
import Nav from '../components/Nav.astro'
import { siteIdentity, toAbsoluteUrl } from '../data/site'
import { buildArticleSeoMetadata, serializeJsonLd } from '../utils/seo'

interface ArticleMetadata {
  publishedAt: Date
  updatedAt?: Date
  tags?: readonly string[]
}

interface Props {
  title?: string
  description?: string
  canonicalPath?: string
  imagePath?: string
  type?: 'website' | 'article'
  articleMetadata?: ArticleMetadata
}

const {
  title = siteIdentity.defaultTitle,
  description = siteIdentity.defaultDescription,
  canonicalPath = Astro.url.pathname,
  imagePath = siteIdentity.socialImagePath,
  type = 'website',
  articleMetadata,
} = Astro.props

const pageTitle = title === siteIdentity.defaultTitle ? title : `${title} · ${siteIdentity.siteName}`
const canonicalUrl = toAbsoluteUrl(canonicalPath)
const imageUrl = toAbsoluteUrl(imagePath)
const articleSeo = articleMetadata
  ? buildArticleSeoMetadata({
      title,
      description,
      canonicalUrl,
      imageUrl,
      publishedAt: articleMetadata.publishedAt,
      modifiedAt: articleMetadata.updatedAt,
      tags: articleMetadata.tags,
      authorName: siteIdentity.ownerName,
      siteName: siteIdentity.siteName,
      siteUrl: toAbsoluteUrl('/'),
    })
  : undefined
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteIdentity.siteName} RSS`} href={toAbsoluteUrl('/rss.xml')} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteIdentity.siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={siteIdentity.socialImageAlt} />
    {articleSeo?.keywords && <meta name="keywords" content={articleSeo.keywords} />}
    {articleSeo && <meta property="article:published_time" content={articleSeo.publishedTime} />}
    {articleSeo?.modifiedTime && <meta property="article:modified_time" content={articleSeo.modifiedTime} />}
    {articleSeo && <meta property="article:author" content={siteIdentity.ownerName} />}
    {articleSeo?.tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={siteIdentity.socialImageAlt} />
    {articleSeo && <script type="application/ld+json" is:inline set:html={serializeJsonLd(articleSeo.jsonLd)} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="site-frame">
        <Nav />
        <main>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
