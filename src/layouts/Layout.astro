---
import '../styles/global.css'
import Footer from '../components/Footer.astro'
import Nav from '../components/Nav.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Jeff Tim', description = 'Quiet notes on backend systems, small tools, and the path from learning to shipping.' } = Astro.props

const pageTitle = title === 'Jeff Tim' ? title : `${title} · Jeff Tim`
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="site-frame">
        <Nav />
        <main>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
