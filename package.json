{
  "name": "personal-blog-v1",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "predev": "npm run sync:content",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "prebuild": "npm run sync:content",
    "postbuild": "npm run check:budget:dist",
    "design:baseline": "npm run build && node scripts/capture-design-baseline.mjs",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "prepreview": "npm run sync:content",
    "check": "npm run check:content && ASTRO_TELEMETRY_DISABLED=1 astro check",
    "precheck:content": "npm run sync:content",
    "test": "node --test \"tests/**/*.test.mjs\"",
    "check:budget": "node scripts/check-budget.mjs",
    "check:budget:dist": "node scripts/check-budget.mjs --dist",
    "check:content": "node scripts/check-content.mjs",
    "check:deploy-env": "node scripts/check-deploy-env.mjs",
    "check:deployment-health": "node scripts/check-deployment-health.mjs",
    "check:origin": "node scripts/check-origin.mjs",
    "build:deploy": "npm run check:origin && PRIVATE_CONTENT_STRICT=1 npm run build",
    "sync:content": "node scripts/sync-content.mjs",
    "sync:content:strict": "node scripts/sync-content.mjs --strict"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "astro": "^6.3.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^24.12.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "volar-service-yaml": "0.0.71"
  }
}
